# 生产环境配置文件
# 复制此文件为 .env 并根据实际情况修改

# ==================== 服务器配置 ====================
# 服务器的公网IP或域名，用于Kafka外部访问
KAFKA_EXTERNAL_HOST=your-server-ip-or-domain.com

# ==================== 数据库凭证（可选修改） ====================
# PostgreSQL配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=orchestrator

# 如果您想修改数据库凭证，请同时修改以下配置：
# MongoDB认证（如需启用，取消注释并设置）
# MONGO_INITDB_ROOT_USERNAME=admin
# MONGO_INITDB_ROOT_PASSWORD=your-mongo-password

# Redis密码（如需启用，取消注释并设置）
# REDIS_PASSWORD=your-redis-password

# ==================== 应用配置 ====================
# 应用服务调试模式
AUTH_SERVICE_DEBUG=false

# ==================== 资源限制 ====================
# 内存限制（根据服务器配置调整）
MEMORY_LIMIT_POSTGRES=512m
MEMORY_LIMIT_MONGODB=512m
MEMORY_LIMIT_REDIS=256m
MEMORY_LIMIT_KAFKA=1024m
MEMORY_LIMIT_ZOOKEEPER=256m
MEMORY_LIMIT_AUTH_SERVICE=512m
MEMORY_LIMIT_ORCHESTRATOR_SERVICE=512m
MEMORY_LIMIT_USER_SERVICE=512m

# CPU限制（根据服务器配置调整）
CPU_LIMIT_POSTGRES=0.5
CPU_LIMIT_MONGODB=0.5
CPU_LIMIT_REDIS=0.2
CPU_LIMIT_KAFKA=1.0
CPU_LIMIT_ZOOKEEPER=0.2
CPU_LIMIT_AUTH_SERVICE=0.5
CPU_LIMIT_ORCHESTRATOR_SERVICE=0.5
CPU_LIMIT_USER_SERVICE=0.5