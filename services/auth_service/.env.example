# 应用配置
APP_NAME=Auth Service
DESCRIPTION=用户认证服务
VERSION=1.0.0
DEBUG=True

# 服务器配置
HOST=127.0.0.1
PORT=9030

# 数据库配置
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=TDL_local_test_database

# JWT配置
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

# CORS配置
ALLOWED_ORIGINS=["*"]
ALLOWED_METHODS=["*"]
ALLOWED_HEADERS=["*"]
