{
  "rate_limits": {
    "/api/v1/auth/send_code": {
      "capacity": 10,
      "rate": 1.0,
      "burst": 5,
      "window": 3600,
      "warmup": 0,
      "enabled": true
    },
    "/api/v1/auth/login": {
      "capacity": 5,
      "rate": 0.5,
      "burst": 2,
      "window": 300,
      "warmup": 0,
      "enabled": true
    },
    "/api/v1/auth/register": {
      "capacity": 3,
      "rate": 0.2,
      "burst": 1,
      "window": 3600,
      "warmup": 0,
      "enabled": true
    },
    "/api/v1/auth/verify_code": {
      "capacity": 20,
      "rate": 2.0,
      "burst": 10,
      "window": 300,
      "warmup": 0,
      "enabled": true
    },
    "/api/v1/auth/verify_code_login": {
      "capacity": 15,
      "rate": 1.5,
      "burst": 8,
      "window": 600,
      "warmup": 0,
      "enabled": true
    },
    "/api/v1/auth/reset_password": {
      "capacity": 5,
      "rate": 0.3,
      "burst": 2,
      "window": 3600,
      "warmup": 0,
      "enabled": true
    },
    "/api/v1/auth/refresh_token": {
      "capacity": 50,
      "rate": 5.0,
      "burst": 20,
      "window": 3600,
      "warmup": 0,
      "enabled": true
    },
    "/api/v1/auth/logout": {
      "capacity": 100,
      "rate": 10.0,
      "burst": 50,
      "window": 3600,
      "warmup": 0,
      "enabled": true
    }
  },
  "global_settings": {
    "redis_key_prefix": "rate_limit",
    "default_capacity": 100,
    "default_rate": 10.0,
    "max_wait_time": 3600,
    "enable_logging": true
  }
}