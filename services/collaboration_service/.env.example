# 服务配置
PORT=8080
ENV=development

# MySQL数据库
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=collaboration_db
MYSQL_USERNAME=root
MYSQL_PASSWORD=password

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DATABASE=collaboration_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=collaboration-service

# JWT配置
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRE=24h

# gRPC配置
GRPC_HOST=localhost
GRPC_PORT=50051